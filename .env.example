# Copy to .env locally. On AWS, use the console / Secrets Manager — never commit .env.

# --- Required for AI ---
OPENAI_API_KEY=

# --- Auth (generate: python -c "import secrets; print(secrets.token_urlsafe(48))") ---
JWT_SECRET=change-me-in-development-only
# Optional alias (auth accepts either):
# SECRET_KEY=

# --- HTTP / CORS ---
# Local: omit ENVIRONMENT or leave non-production for permissive CORS.
# AWS: set production and list your Amplify URL(s) exactly (scheme + host, no trailing slash):
ENVIRONMENT=production
# Example: ALLOWED_ORIGINS=https://main.d2kv8ogbmqo46z.amplifyapp.com
ALLOWED_ORIGINS=

# --- Database ---
# Local SQLite (default): sqlite:///./app.db
# Local legacy path: sqlite:///./backend/data/recruiter.db
# AWS + EFS: mount volume at e.g. /data and use:
# DATABASE_URL=sqlite:////data/recruiter.db
# PostgreSQL (RDS): DATABASE_URL=postgresql+psycopg2://USER:PASS@host:5432/dbname
DATABASE_URL=sqlite:///./app.db

USE_DATABASE=true

# --- Optional: email monitoring (see GMAIL_SETUP.md) ---
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
