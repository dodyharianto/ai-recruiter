# Copy to .env in this folder (project root) and fill in values. Never commit .env.

# Required for AI features (agents, transcription, parsing)
OPENAI_API_KEY=

# Strong random string for JWT signing (required in production)
JWT_SECRET=change-me-in-development-only

# Optional: SQLite URL (default sqlite:///./app.db). Use legacy DB under backend/data:
# DATABASE_URL=sqlite:///./backend/data/recruiter.db

# Optional: set to production to tighten CORS in main.py
# ENVIRONMENT=production

# Optional: set to false to use JSON files under backend/data instead of SQLite
# USE_DATABASE=true

# Optional: email monitoring (see GMAIL_SETUP.md)
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
